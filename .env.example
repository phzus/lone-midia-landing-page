# ==== Lone Mídia — variáveis de ambiente ====
# Copie para .env.local e preencha. NUNCA commitar .env.local.
# Tudo NEXT_PUBLIC_ é exposto ao browser (use só para valores públicos).

# URL de produção (canonical/SEO). Ex.: https://lonemidia.com.br
NEXT_PUBLIC_SITE_URL=

# Número de WhatsApp de contato (E.164 sem +). Ex.: 5541999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Meta Pixel (público). ID do pixel.
NEXT_PUBLIC_META_PIXEL_ID=

# Cloudflare Turnstile (anti-spam). Site key é pública; secret é server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# n8n self-hosted (server-only). URL do webhook + secret p/ assinatura HMAC.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# Rate-limit (Upstash Redis, server-only). Opcional em dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Salt p/ hashear IP nos logs/consentimento (server-only).
IP_SALT=

# Versão da política de privacidade (registrada na prova de consentimento).
CONSENT_VERSION=1.0
